# ── Histolink Backend — Plantilla de variables de entorno ────────────────
# Copiar este archivo como .env y completar los valores.

SECRET_KEY=cambiar-por-una-clave-segura-generada-con-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=False

# Base de datos PostgreSQL
DB_NAME=histolink
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379
