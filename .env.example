# ── Histolink Backend — Plantilla de variables de entorno ────────────────
# Copiar este archivo como .env y completar los valores.

SECRET_KEY=cambiar-por-una-clave-segura-generada-con-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,tu-app.railway.app
CORS_ALLOW_ALL_ORIGINS=True

# Base de datos PostgreSQL
# En Railway estas variables se generan automáticamente al agregar el plugin Postgres.
# En desarrollo local, completar manualmente.
PGDATABASE=histolink
PGUSER=postgres
PGPASSWORD=tu_password_aqui
PGHOST=localhost
PGPORT=5432

# Redis (opcional — sin esto usa caché en memoria)
REDIS_URL=redis://127.0.0.1:6379

# Superusuario (creado automáticamente en el primer deploy por el start command)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CambiarEsto123!
DJANGO_SUPERUSER_EMAIL=admin@histolink.com
